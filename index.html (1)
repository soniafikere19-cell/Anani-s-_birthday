<script>
  const SITE_PASSWORD = "2000,1999";
  const gate = document.getElementById('gate');
  const input = document.getElementById('password-input');
  const submitBtn = document.getElementById('gate-submit');
  const errorMsg = document.getElementById('gate-error');
  const site = document.getElementById('site');
  const lilyOverlay = document.getElementById('lily-overlay');
  const lilySvg = document.getElementById('lily-svg');
  const unlockNames = document.getElementById('unlock-names');
  const unlockSub = document.getElementById('unlock-sub');
  function tryEnter(){
    if(input.value.trim().toLowerCase() === SITE_PASSWORD.trim().toLowerCase()){ unlockWithLily(); }
    else { errorMsg.classList.add('show'); input.focus(); input.select(); }
  }
  function spawnFloatingLilies(){
    const symbols = ['❀','✿','❁'];
    const count = window.innerWidth < 600 ? 18 : 32;
    for(let i=0; i<count; i++){
      const span = document.createElement('span');
      span.className = 'burst-lily';
      span.textContent = symbols[Math.floor(Math.random()*symbols.length)];
      const size = 12 + Math.random()*22;
      span.style.fontSize = size + 'px';
      span.style.left = (10 + Math.random()*80) + '%';
      span.style.top = (10 + Math.random()*80) + '%';
      span.style.setProperty('--bx', (Math.random()*260-130) + 'px');
      span.style.setProperty('--by', (Math.random()*260-160) + 'px');
      span.style.setProperty('--br', (Math.random()*260) + 'deg');
      const duration = 2.4 + Math.random()*1.6;
      span.style.animationDuration = duration + 's';
      span.style.animationDelay = (Math.random()*.6) + 's';
      lilyOverlay.appendChild(span);
      setTimeout(() => span.remove(), (duration+1)*1000);
    }
  }
  function unlockWithLily(){
    gate.classList.add('hidden');
    lilyOverlay.classList.add('active');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => requestAnimationFrame(() => { lilySvg.classList.add('bloom'); }));
    setTimeout(spawnFloatingLilies, 1500);
    setTimeout(() => unlockNames.classList.add('show'), 2000);
    setTimeout(() => unlockSub.classList.add('show'), 2900);
    setTimeout(() => {
      lilyOverlay.classList.add('fade-out');
      site.classList.add('revealed');
      document.body.style.overflow = 'auto';
      startReveal(); startCountdown(); buildStars();
      setTimeout(() => { lilyOverlay.classList.remove('active','fade-out'); unlockNames.classList.remove('show'); unlockSub.classList.remove('show'); }, 1200);
    }, 4400);
  }
  submitBtn.addEventListener('click', tryEnter);
  input.addEventListener('keydown', e => { if(e.key === 'Enter') tryEnter(); });
  input.addEventListener('input', () => errorMsg.classList.remove('show'));
  document.body.style.overflow = 'hidden';
  (function gateDecor(){
    const wrap = document.getElementById('gate-decor');
    for(let i=0;i<4;i++){
      const c = document.createElement('div'); c.className = 'gate-cloud';
      const w = 90 + Math.random()*100;
      c.style.width = w+'px'; c.style.height = (w*0.4)+'px';
      c.style.left = (Math.random()*80)+'%'; c.style.top = (10+Math.random()*60)+'%';
      c.style.background = 'radial-gradient(ellipse at center, #fffdf7 0%, rgba(255,253,247,0) 70%)';
      c.style.borderRadius = '50%';
      c.style.animationDuration = (18+Math.random()*14)+'s';
      c.style.animationDirection = i%2? 'alternate-reverse':'alternate';
      wrap.appendChild(c);
    }
    for(let i=0;i<16;i++){
      const s = document.createElement('span'); s.className = 'gate-sparkle'; s.textContent = '✦';
      s.style.left = Math.random()*100+'%'; s.style.top = Math.random()*100+'%';
      s.style.fontSize = (6+Math.random()*8)+'px'; s.style.animationDelay = (Math.random()*3)+'s';
      wrap.appendChild(s);
    }
    for(let i=0;i<10;i++){
      const l = document.createElement('span'); l.className = 'gate-lily'; l.textContent = Math.random()>0.5 ? '❀' : '✿';
      l.style.left = Math.random()*100+'%'; l.style.top = Math.random()*100+'%';
      l.style.fontSize = (12+Math.random()*14)+'px';
      l.style.setProperty('--gx',(Math.random()*80-40)+'px'); l.style.setProperty('--gy',(Math.random()*60-30)+'px');
      l.style.animationDuration = (10+Math.random()*8)+'s'; l.style.animationDelay = (Math.random()*6)+'s';
      wrap.appendChild(l);
    }
    for(let i=0;i<3;i++){
      const k = document.createElement('div'); k.className = 'gate-lock'; k.innerHTML = '&#128274;';
      k.style.left = (10+Math.random()*80)+'%'; k.style.top = (65+Math.random()*25)+'%';
      k.style.fontSize = (18+Math.random()*10)+'px'; k.style.animationDelay = (Math.random()*4)+'s';
      wrap.appendChild(k);
    }
  })();
  const HERO_PHOTOS = ["photo1.jpg","photo2.jpg","photo3.jpg","photo4.jpg"];
  const PLACEHOLDER_GRADIENTS = ['linear-gradient(135deg, #0a1130, #1e3a8a)','linear-gradient(135deg, #04060f, #14247a)','linear-gradient(135deg, #0e1638, #3d63f5)'];
  (function buildHero(){
    const wrap = document.getElementById('hero-slides');
    const sources = HERO_PHOTOS.length ? HERO_PHOTOS : PLACEHOLDER_GRADIENTS;
    sources.forEach((src, i) => {
      const div = document.createElement('div');
      div.className = 'hero-slide' + (i === 0 ? ' active' : '');
      if(HERO_PHOTOS.length){ div.style.backgroundImage = `url("${src}")`; } else { div.style.background = src; }
      wrap.appendChild(div);
    });
    const slides = wrap.querySelectorAll('.hero-slide'); let current = 0;
    if(slides.length > 1){ setInterval(() => { slides[current].classList.remove('active'); current = (current+1)%slides.length; slides[current].classList.add('active'); }, 5000); }
    window.addEventListener('scroll', () => { const y = window.scrollY; if(y < window.innerHeight){ wrap.style.transform = `translateY(${y * 0.25}px)`; } }, { passive:true });
  })();
  function startReveal(){
    const els = document.querySelectorAll('.reveal');
    const io = new IntersectionObserver((entries) => { entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('in'); }); }, { threshold: 0.15 });
    els.forEach(el => io.observe(el));
    setTimeout(() => els.forEach(el => { const r = el.getBoundingClientRect(); if(r.top < window.innerHeight) el.classList.add('in'); }), 100);
  }
  const NEXT_DATE = new Date(2026, 11, 24, 18, 0);
  function startCountdown(){
    function update(){
      const now = new Date(); let diff = NEXT_DATE - now; if(diff < 0) diff = 0;
      const days = Math.floor(diff / (1000*60*60*24));
      const hours = Math.floor((diff / (1000*60*60)) % 24);
      const mins = Math.floor((diff / (1000*60)) % 60);
      const secs = Math.floor((diff / 1000) % 60);
      document.getElementById('cd-days').textContent = days;
      document.getElementById('cd-hours').textContent = String(hours).padStart(2,'0');
      document.getElementById('cd-mins').textContent = String(mins).padStart(2,'0');
      document.getElementById('cd-secs').textContent = String(secs).padStart(2,'0');
    }
    update(); setInterval(update, 1000);
  }
  (function cake(){
    const candles = Array.from(document.querySelectorAll('[data-candle]'));
    const confettiLayer = document.getElementById('confetti-layer');
    const message = document.getElementById('birthday-message');
    let celebrated = false;
    function allOut(){ return candles.every(c => c.classList.contains('out')); }
    function launchConfetti(){
      const colors = ['#f2a9c4','#fbdce7','#3d63f5','#d8b566','#f7f9ff'];
      const shapes = ['❀','✿','●','▮'];
      const count = window.innerWidth < 600 ? 40 : 70;
      for(let i=0; i<count; i++){
        const bit = document.createElement('span'); bit.className = 'confetti-bit';
        const isFlower = Math.random() > 0.55;
        bit.textContent = isFlower ? shapes[Math.floor(Math.random()*2)] : shapes[2+Math.floor(Math.random()*2)];
        bit.style.color = colors[Math.floor(Math.random()*colors.length)];
        bit.style.left = Math.random()*100 + '%';
        bit.style.fontSize = (isFlower ? 10+Math.random()*10 : 6+Math.random()*6) + 'px';
        bit.style.setProperty('--spin', (Math.random()*720-360) + 'deg');
        const duration = 2.6 + Math.random()*2.2;
        bit.style.animationDuration = duration + 's'; bit.style.animationDelay = (Math.random()*.5) + 's';
        confettiLayer.appendChild(bit);
        setTimeout(() => bit.remove(), (duration+1)*1000);
      }
    }
    candles.forEach(candle => {
      candle.addEventListener('click', () => {
        if(candle.classList.contains('out')) return;
        candle.classList.add('out');
        if(!celebrated && allOut()){ celebrated = true; launchConfetti(); setTimeout(() => message.classList.add('show'), 400); }
      });
    });
  })();
  const MEMORIES = [
    { caption: "Memory One", date: "Month Year", note: "A short note about this photo." },
    { caption: "Memory Two", date: "Month Year", note: "A short note about this photo." },
    { caption: "Memory Three", date: "Month Year", note: "A short note about this photo." },
    { caption: "Memory Four", date: "Month Year", note: "A short note about this photo." },
    { caption: "Memory Five", date: "Month Year", note: "A short note about this photo." },
    { caption: "Memory Six", date: "Month Year", note: "A short note about this photo." }
  ];
  (function lightbox(){
    const grid = document.getElementById('memories-grid');
    const items = () => Array.from(grid.querySelectorAll('.mem-item'));
    const lb = document.getElementById('lightbox');
    const lbContent = document.getElementById('lb-content');
    const lbCaption = document.getElementById('lb-caption-text');
    const lbDate = document.getElementById('lb-date-text');
    const lbNote = document.getElementById('lb-note-text');
    let index = 0;
    function render(){
      const el = items()[index];
      const img = el.querySelector('img');
      lbContent.innerHTML = '';
      if(img){ const big = document.createElement('img'); big.src = img.src; big.alt = img.alt || ''; lbContent.appendChild(big); }
      else { const ph = document.createElement('div'); ph.className = 'lb-placeholder'; ph.textContent = el.textContent.trim(); lbContent.appendChild(ph); }
      const info = MEMORIES[index] || {};
      lbCaption.textContent = info.caption || ''; lbDate.textContent = info.date || ''; lbNote.textContent = info.note || '';
    }
    function open(i){ index = i; render(); lb.classList.add('open'); }
    function close(){ lb.classList.remove('open'); }
    function next(){ index = (index + 1) % items().length; render(); }
    function prev(){ index = (index - 1 + items().length) % items().length; render(); }
    grid.addEventListener('click', e => { const el = e.target.closest('.mem-item'); if(!el) return; open(items().indexOf(el)); });
    document.getElementById('lb-close').addEventListener('click', close);
    document.getElementById('lb-next').addEventListener('click', next);
    document.getElementById('lb-prev').addEventListener('click', prev);
    lb.addEventListener('click', e => { if(e.target === lb) close(); });
    document.addEventListener('keydown', e => { if(!lb.classList.contains('open')) return; if(e.key === 'Escape') close(); if(e.key === 'ArrowRight') next(); if(e.key === 'ArrowLeft') prev(); });
  })();
  function buildStars(){
    const layer = document.getElementById('stars-layer');
    if(!layer || layer.dataset.built) return;
    layer.dataset.built = '1';
    for(let i=0;i<60;i++){
      const s = document.createElement('div'); s.className = 'star-dot';
      const size = 1 + Math.random()*2;
      s.style.width = size+'px'; s.style.height = size+'px';
      s.style.left = Math.random()*100+'%'; s.style.top = Math.random()*100+'%';
      s.style.animationDelay = (Math.random()*3)+'s';
      layer.appendChild(s);
    }
  }
  (function envelope(){
    const seal = document.getElementById('env-seal');
    const env = document.getElementById('envelope');
    const paper = document.getElementById('letter-paper');
    const petalsWrap = document.getElementById('letter-petals');
    const continueBtn = document.getElementById('continue-btn');
    let opened = false;
    function spawnPetals(){
      for(let i=0;i<14;i++){
        const p = document.createElement('span'); p.className = 'burst-lily';
        p.textContent = Math.random()>0.5 ? '❀' : '✿';
        p.style.left = Math.random()*100+'%'; p.style.top = (Math.random()*40)+'%';
        p.style.fontSize = (10+Math.random()*10)+'px';
        p.style.setProperty('--bx', (Math.random()*140-70)+'px');
        p.style.setProperty('--by', (100+Math.random()*80)+'px');
        p.style.setProperty('--br', (Math.random()*200)+'deg');
        const duration = 3+Math.random()*2;
        p.style.animationDuration = duration+'s'; p.style.animationDelay = (Math.random()*1)+'s';
        petalsWrap.appendChild(p);
        setTimeout(() => p.remove(), (duration+1.2)*1000);
      }
    }
    seal.addEventListener('click', () => {
      if(opened) return; opened = true;
      env.classList.add('open');
      setTimeout(() => { paper.classList.add('show'); spawnPetals(); }, 900);
      setTimeout(() => { continueBtn.classList.add('show'); }, 2600);
    });
    continueBtn.addEventListener('click', () => { document.getElementById('finale').scrollIntoView({ behavior:'smooth' }); });
  })();
  (function ambient(){
    const container = document.getElementById('ambient');
    const count = window.innerWidth < 600 ? 16 : 28;
    for(let i=0; i<count; i++){
      const span = document.createElement('span'); span.className = 'spark';
      const size = 2 + Math.random()*4;
      span.style.width = size + 'px'; span.style.height = size + 'px';
      span.style.left = Math.random()*100 + 'vw';
      span.style.setProperty('--drift-x', (Math.random()*70-35) + 'px');
      const duration = 12 + Math.random()*14;
      span.style.animationDuration = duration + 's'; span.style.animationDelay = (Math.random()*duration) + 's';
      container.appendChild(span);
    }
  })();
  window.addEventListener('load', () => input.focus());
</script>
