<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Anani's Birthday</title>
<meta name="robots" content="noindex, nofollow">

<style>
  :root{
    --void:      #04060f;
    --navy:      #0a1130;
    --blue:      #14247a;
    --electric:  #3d63f5;
    --pink:      #f2a9c4;
    --pink-pale: #fbdce7;
    --gold:      #d8b566;
    --ice:       #dce6ff;
    --silver:    #b9c4de;
    --white:     #f7f9ff;
    --paper:     #0e1638;
    --cream:     #fdf1dd;
    --cream-deep:#f7dfc0;
    --sky-gold:  #e8bf7e;
    --sky-blush: #f3c7d6;
    --sky-dusk:  #a9789a;
    --kiss-red:      #c81d43;
    --kiss-red-deep: #7d0f2c;
    --font-display: 'Cinzel', Georgia, serif;
    --font-script:  'Great Vibes', cursive;
    --font-hand:    'Caveat', cursive;
    --font-accent:  'Cormorant Garamond', Georgia, serif;
    --font-body:    'Jost', -apple-system, sans-serif;
  }
  *{ box-sizing:border-box; margin:0; padding:0; }
  html{ scroll-behavior:smooth; }
  body{ font-family: var(--font-body); background: var(--navy); color: var(--ice); overflow-x:hidden; -webkit-font-smoothing:antialiased; }
  @media (prefers-reduced-motion: reduce){ *{ animation-duration:.001ms !important; animation-iteration-count:1 !important; transition-duration:.001ms !important; scroll-behavior:auto !important; } }
  img{ max-width:100%; display:block; }
  button{ font-family:inherit; }
  #ambient{ position:fixed; inset:0; pointer-events:none; z-index:5; overflow:hidden; }
  .spark{ position:absolute; bottom:-6%; border-radius:50%; background: radial-gradient(circle, var(--white) 0%, var(--electric) 60%, transparent 100%); opacity:0; animation: sparkRise linear infinite; box-shadow: 0 0 6px var(--electric); }
  @keyframes sparkRise{ 0%{ transform: translateY(0) translateX(0); opacity:0; } 10%{ opacity:.8; } 90%{ opacity:.4; } 100%{ transform: translateY(-112vh) translateX(var(--drift-x,20px)); opacity:0; } }
  section{ position:relative; z-index:2; min-height:100vh; width:100%; padding: 6.5rem 1.5rem; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; }
  h1,h2,h3{ font-family: var(--font-display); color: var(--white); font-weight:600; letter-spacing:.02em; }
  .script{ font-family: var(--font-script); color: var(--pink); font-weight:400; }
  .eyebrow{ letter-spacing:.32em; text-transform:uppercase; font-size:.66rem; color: var(--silver); margin-bottom:1.1rem; font-weight:500; }
  .rule{ width:52px; height:1px; background:var(--pink); margin:1.5rem auto; opacity:.9; box-shadow:0 0 8px var(--pink); }
  .reveal{ opacity:0; transform:translateY(26px); transition: opacity .9s ease, transform .9s ease; }
  .reveal.in{ opacity:1; transform:translateY(0); }
  #gate{ position:fixed; inset:0; z-index:100; overflow:hidden; background: radial-gradient(circle at 20% 15%, rgba(255,255,255,0.5) 0%, transparent 8%), radial-gradient(circle at 70% 65%, var(--sky-blush) 0%, transparent 55%), radial-gradient(circle at 15% 80%, var(--sky-gold) 0%, transparent 55%), linear-gradient(160deg, var(--cream) 0%, var(--cream-deep) 55%, var(--sky-dusk) 130%); display:flex; align-items:center; justify-content:center; padding:1.5rem; transition: opacity 1s ease, visibility 1s ease; }
  #gate.hidden{ opacity:0; visibility:hidden; pointer-events:none; }
  .gate-moon{ position:absolute; top:8%; right:12%; width:70px; height:70px; z-index:1; filter: drop-shadow(0 0 20px rgba(255,255,255,0.7)); opacity:.9; }
  .gate-cloud{ position:absolute; z-index:1; opacity:.55; filter:blur(1px); animation: cloudDrift linear infinite; }
  @keyframes cloudDrift{ 0%{ transform: translateX(-8vw); } 100%{ transform: translateX(8vw); } }
  .gate-lock{ position:absolute; z-index:1; opacity:.35; color:var(--sky-dusk); animation: lockFloat 7s ease-in-out infinite; }
  @keyframes lockFloat{ 0%,100%{ transform:translateY(0) rotate(-4deg);} 50%{ transform:translateY(-10px) rotate(4deg);} }
  .gate-sparkle{ position:absolute; z-index:1; color:#fff; opacity:0; animation: sparkleTwinkle 3s ease-in-out infinite; }
  @keyframes sparkleTwinkle{ 0%,100%{ opacity:0; transform:scale(0.6);} 50%{ opacity:.9; transform:scale(1);} }
  .gate-lily{ position:absolute; z-index:1; color:var(--pink); opacity:0; animation: gateLilyDrift linear infinite; }
  @keyframes gateLilyDrift{ 0%{ opacity:0; transform: translate(0,0) rotate(0deg); } 10%{ opacity:.75; } 90%{ opacity:.5; } 100%{ opacity:0; transform: translate(var(--gx,60px), var(--gy,-40px)) rotate(180deg); } }
  .gate-heart{ position:relative; width:56px; height:50px; margin:0 auto 1.4rem; z-index:2; filter: drop-shadow(0 0 14px #fff) drop-shadow(0 0 26px var(--sky-blush)); animation: heartPulse 3.2s ease-in-out infinite; }
  .gate-heart svg{ width:100%; height:100%; display:block; }
  @keyframes heartPulse{ 0%,100%{ transform:scale(1); } 50%{ transform:scale(1.08); } }
  .gate-card{ position:relative; z-index:2; text-align:center; max-width:380px; width:100%; }
  .gate-card h2{ font-family:var(--font-display); font-size:1.5rem; color:#5a4030; margin-bottom:.4rem; letter-spacing:.06em; }
  .gate-card p{ color:#8a6a52; font-size:.86rem; margin-bottom:1.8rem; font-family:var(--font-body); }
  #password-input{ width:100%; padding:.95rem 1.1rem; border-radius:2px; border:1px solid rgba(90,64,48,0.3); font-family:var(--font-body); font-size:1rem; text-align:center; letter-spacing:.2em; outline:none; background:rgba(255,250,240,0.6); color:#5a4030; transition:border-color .3s ease, box-shadow .3s ease; }
  #password-input::placeholder{ color:rgba(90,64,48,0.4); }
  #password-input:focus{ border-color:var(--sky-dusk); box-shadow:0 0 14px rgba(169,120,154,0.4); }
  #gate-submit{ margin-top:1.1rem; width:100%; padding:.9rem 1rem; border:1px solid var(--sky-dusk); border-radius:2px; background: rgba(255,255,255,0.35); color:#5a4030; font-family:var(--font-display); font-size:.9rem; letter-spacing:.15em; text-transform:uppercase; cursor:pointer; transition: background .3s ease, box-shadow .3s ease; }
  #gate-submit:hover{ background:rgba(255,255,255,0.6); box-shadow:0 0 20px rgba(169,120,154,0.4); }
  #gate-error{ margin-top:.9rem; font-size:.8rem; color:#a5303e; min-height:1.1em; opacity:0; transition:opacity .3s ease; }
  #gate-error.show{ opacity:1; }
  #lily-overlay{ position:fixed; inset:0; z-index:150; background:var(--void); display:flex; align-items:center; justify-content:center; opacity:0; visibility:hidden; pointer-events:none; overflow:hidden; transition: opacity 1.1s ease .1s; }
  #lily-overlay.active{ opacity:1; visibility:visible; }
  #lily-overlay.fade-out{ opacity:0; }
  #lily-svg{ width:min(60vw,270px); height:min(60vw,270px); overflow:visible; position:relative; z-index:2; }
  .petal-outer{ transform-origin: 100px 100px; transform: rotate(var(--rot,0deg)) scale(0.12); opacity:0; transition: transform 1.6s cubic-bezier(.19,1,.22,1), opacity 1.1s ease; transition-delay: var(--delay, 0s); }
  .petal-inner{ transform-origin: 100px 100px; transform: rotate(var(--rot,0deg)) scale(0.1); opacity:0; transition: transform 1.4s cubic-bezier(.19,1,.22,1), opacity 1s ease; transition-delay: calc(var(--delay, 0s) + .35s); }
  #lily-svg.bloom .petal-outer{ transform: rotate(var(--rot,0deg)) scale(1); opacity:1; }
  #lily-svg.bloom .petal-inner{ transform: rotate(var(--rot,0deg)) scale(1); opacity:1; }
  .stamen{ opacity:0; transition: opacity .8s ease 1.3s; }
  #lily-svg.bloom .stamen{ opacity:1; }
  .unlock-text{ position:absolute; z-index:3; left:50%; top:50%; transform:translate(-50%,-50%); text-align:center; white-space:nowrap; }
  .unlock-names{ font-family:var(--font-script); font-size:clamp(2.2rem,8vw,3.6rem); color:var(--pink); text-shadow:0 0 24px rgba(242,169,196,0.6); opacity:0; transition:opacity 1.2s ease; }
  .unlock-names.show{ opacity:1; }
  .unlock-sub{ margin-top:.6rem; font-family:var(--font-display); font-size:clamp(1rem,3.4vw,1.5rem); color:var(--white); letter-spacing:.08em; opacity:0; transition:opacity 1.2s ease; text-shadow:0 0 16px rgba(61,99,245,0.5); }
  .unlock-sub.show{ opacity:1; }
  .burst-lily{ position:absolute; z-index:1; color:var(--pink); opacity:0; pointer-events:none; animation: burstDrift linear forwards; }
  @keyframes burstDrift{ 0%{ opacity:0; transform: translate(0,0) rotate(0deg) scale(0.7); } 12%{ opacity:.9; } 85%{ opacity:.7; } 100%{ opacity:0; transform: translate(var(--bx,120px), var(--by,-160px)) rotate(var(--br,180deg)) scale(1); } }
  #site{ opacity:0; transition:opacity 1.2s ease; }
  #site.revealed{ opacity:1; }
  #cake{ background: radial-gradient(circle at 50% 30%, var(--blue) 0%, var(--void) 70%); overflow:hidden; }
  .cake-wrap{ position:relative; z-index:2; max-width:420px; width:100%; }
  .make-a-wish{ font-family:var(--font-script); font-size:clamp(1.6rem,6vw,2.4rem); color:var(--pink); margin-bottom:2.2rem; text-shadow:0 0 20px rgba(242,169,196,0.5); }
  .cake{ position:relative; width:220px; margin:0 auto; }
  .candles{ display:flex; justify-content:center; gap:22px; position:relative; z-index:3; height:70px; }
  .candle{ position:relative; width:6px; height:46px; background:linear-gradient(180deg,#fff6e0,#e8d3a0); border-radius:2px; cursor:pointer; align-self:flex-end; }
  .flame{ position:absolute; left:50%; top:-20px; transform:translateX(-50%); width:12px; height:20px; border-radius:50% 50% 50% 50% / 60% 60% 40% 40%; background: radial-gradient(circle at 50% 70%, #fff6c8 0%, #ffd166 45%, #ff8c42 80%); box-shadow: 0 0 12px 3px rgba(255,180,80,0.7); animation: flicker 1.6s ease-in-out infinite; transition: opacity .4s ease, transform .4s ease; }
  @keyframes flicker{ 0%,100%{ transform:translateX(-50%) scale(1) rotate(-2deg); } 50%{ transform:translateX(-50%) scale(1.08) rotate(2deg); } }
  .candle.out .flame{ opacity:0; transform:translateX(-50%) scale(0.2); }
  .smoke{ position:absolute; left:50%; top:-22px; transform:translateX(-50%); width:3px; height:0; background:rgba(220,225,240,0.5); border-radius:2px; opacity:0; pointer-events:none; }
  .candle.out .smoke{ animation: smokeRise 1.6s ease-out forwards; }
  @keyframes smokeRise{ 0%{ height:0; opacity:.6; top:-22px; } 100%{ height:34px; opacity:0; top:-56px; } }
  .cake-tiers{ position:relative; z-index:2; }
  .tier{ border-radius:8px; margin:0 auto; box-shadow: inset 0 -6px 14px rgba(0,0,0,0.25), 0 10px 24px rgba(0,0,0,0.35); }
  .tier-top{ width:150px; height:46px; background: linear-gradient(180deg, var(--pink-pale), var(--pink)); position:relative; }
  .tier-top::before{ content:''; position:absolute; top:-8px; left:0; right:0; height:16px; background: repeating-linear-gradient(90deg, var(--white) 0 10px, var(--pink-pale) 10px 20px); border-radius:8px 8px 0 0; }
  .tier-bottom{ width:220px; height:64px; background: linear-gradient(180deg, var(--pink), #d885a8); margin-top:-4px; position:relative; }
  .tier-bottom::before{ content:''; position:absolute; top:-8px; left:0; right:0; height:16px; background: repeating-linear-gradient(90deg, var(--pink-pale) 0 10px, var(--white) 10px 20px); border-radius:8px 8px 0 0; }
  .cake-plate{ width:260px; height:12px; background:linear-gradient(180deg, var(--silver), #7c88a8); border-radius:50%; margin:0 auto; box-shadow:0 6px 18px rgba(0,0,0,0.4); }
  .wish-hint{ margin-top:1.6rem; font-size:.82rem; color:var(--silver); letter-spacing:.05em; }
  #confetti-layer{ position:absolute; inset:0; z-index:4; pointer-events:none; overflow:hidden; }
  .confetti-bit{ position:absolute; top:-5%; opacity:0; animation: confettiFall linear forwards; }
  @keyframes confettiFall{ 0%{ opacity:0; transform: translateY(0) rotate(0deg);} 8%{ opacity:1;} 100%{ opacity:0; transform: translateY(110vh) rotate(var(--spin,360deg)); } }
  .birthday-message{ margin-top:2.4rem; max-width:520px; font-family:var(--font-accent); font-style:italic; font-size:1.14rem; line-height:1.85; color:var(--ice); opacity:0; transform:translateY(16px); transition: opacity 1s ease, transform 1s ease; }
  .birthday-message.show{ opacity:1; transform:translateY(0); }
  #hero{ padding:0; min-height:100vh; justify-content:center; overflow:hidden; color:#fff; }
  .hero-slides{ position:absolute; inset:0; z-index:0; }
  .hero-slide{ position:absolute; inset:-4%; background-size:cover; background-position:center; opacity:0; transition: opacity 2.4s ease; will-change: transform, opacity; }
  .hero-slide.active{ opacity:1; }
  .hero-overlay{ position:absolute; inset:0; z-index:1; background: linear-gradient(180deg, rgba(4,6,15,0.6) 0%, rgba(4,6,15,0.4) 45%, rgba(4,6,15,0.78) 100%); }
  .hero-content{ position:relative; z-index:2; padding:0 1.5rem; }
  .hero-content .eyebrow{ color:rgba(220,230,255,0.8); }
  .hero-names{ font-family: var(--font-script); font-weight:400; font-size: clamp(3rem, 12vw, 5.6rem); line-height:1.2; color:var(--pink); text-shadow: 0 0 30px rgba(242,169,196,0.55); }
  .hero-names .amp{ color: var(--white); font-family:var(--font-accent); font-style:italic; font-size:0.6em; margin:0 .1em; }
  .hero-rule{ width:52px; height:1px; background:var(--pink); margin:1.6rem auto; box-shadow:0 0 10px var(--pink); }
  .hero-message{ max-width:520px; margin:0 auto; font-size:1.06rem; line-height:1.85; color:rgba(240,244,255,0.92); font-weight:300; }
  .scroll-hint{ position:absolute; bottom:2.2rem; left:50%; transform:translateX(-50%); z-index:2; font-size:.68rem; letter-spacing:.22em; color:rgba(220,230,255,0.75); text-transform:uppercase; animation:bob 2.6s ease-in-out infinite; }
  @keyframes bob{ 0%,100%{transform:translate(-50%,0);} 50%{transform:translate(-50%,6px);} }
  #story{ background:var(--void); }
  .story-card{ max-width:620px; width:100%; background:var(--paper); border:1px solid rgba(242,169,196,0.2); border-radius:6px; padding:2.6rem 2.2rem; box-shadow:0 20px 60px rgba(0,0,0,0.4); }
  .story-mark{ font-family:var(--font-script); font-size:2.4rem; color:var(--pink); display:block; margin-bottom:.6rem; text-shadow:0 0 16px rgba(242,169,196,0.5); }
  .story-text{ font-family:var(--font-accent); font-size:1.18rem; line-height:1.95; color:var(--ice); font-weight:400; text-align:left; }
  #reasons{ background:var(--navy); }
  .reasons-list{ max-width:580px; width:100%; margin-top:2.2rem; text-align:left; display:grid; gap:1rem; }
  .reason{ background:var(--paper); border-radius:4px; padding:1.1rem 1.3rem; display:flex; gap:.9rem; align-items:flex-start; box-shadow:0 8px 20px rgba(0,0,0,0.3); border:1px solid rgba(242,169,196,0.15); }
  .reason .mark{ color:var(--pink); font-family:var(--font-accent); font-style:italic; font-size:1.2rem; flex-shrink:0; text-shadow:0 0 8px rgba(242,169,196,0.5); }
  .reason p{ font-size:.96rem; font-weight:300; line-height:1.6; color:var(--ice); }
  #playlist{ background:var(--void); }
  .playlist-wrap{ max-width:540px; width:100%; margin-top:2.2rem; display:grid; gap:.85rem; text-align:left; }
  .track{ background:var(--paper); border-radius:4px; padding:1rem 1.2rem; display:flex; align-items:center; gap:1rem; box-shadow:0 8px 20px rgba(0,0,0,0.3); border:1px solid rgba(242,169,196,0.15); }
  .track-note{ color: var(--pink); font-family:var(--font-accent); font-style:italic; font-size:1.4rem; flex-shrink:0; text-shadow:0 0 8px rgba(242,169,196,0.5); }
  .track-info{ flex:1; }
  .track-title{ font-family:var(--font-display); font-size:1rem; color:var(--white); }
  .track-artist{ font-size:.82rem; color:var(--silver); margin-top:.15rem; }
  .track audio{ width:100%; margin-top:.6rem; height:32px; }
  #memories{ background:var(--navy); }
  .memories-wrap{ max-width:900px; width:100%; }
  .masonry{ column-count:2; column-gap:1rem; margin-top:2.2rem; }
  @media(min-width:640px){ .masonry{ column-count:3; } }
  .mem-item{ break-inside:avoid; margin-bottom:1rem; border-radius:6px; overflow:hidden; cursor:pointer; background: linear-gradient(135deg, var(--paper), var(--blue)); display:flex; align-items:center; justify-content:center; color:var(--pink); font-size:1.5rem; box-shadow:0 10px 26px rgba(0,0,0,0.35); border:1px solid rgba(242,169,196,0.18); transition: transform .4s ease; }
  .mem-item:hover{ transform:scale(1.02); }
  .mem-item img{ width:100%; display:block; }
  .mem-item.ph1{ height:200px; } .mem-item.ph2{ height:260px; } .mem-item.ph3{ height:170px; }
  .mem-item.ph4{ height:230px; } .mem-item.ph5{ height:190px; } .mem-item.ph6{ height:250px; }
  #lightbox{ position:fixed; inset:0; z-index:200; background:rgba(2,4,10,0.95); display:flex; align-items:center; justify-content:center; opacity:0; visibility:hidden; transition:opacity .35s ease, visibility .35s ease; padding:2rem; }
  #lightbox.open{ opacity:1; visibility:visible; }
  .lb-inner{ max-width:min(90vw,620px); text-align:center; }
  #lightbox img, .lb-placeholder{ max-width:100%; max-height:60vh; border-radius:4px; box-shadow:0 0 60px rgba(61,99,245,0.3); margin:0 auto; }
  .lb-placeholder{ width:min(80vw,420px); aspect-ratio:4/3; background:linear-gradient(135deg,var(--paper),var(--blue)); display:flex; align-items:center; justify-content:center; color:var(--pink); font-size:2rem; }
  .lb-caption{ margin-top:1rem; font-family:var(--font-display); color:var(--white); font-size:1.05rem; }
  .lb-date{ font-size:.7rem; letter-spacing:.15em; text-transform:uppercase; color:var(--pink); margin-top:.3rem; }
  .lb-note{ margin-top:.5rem; font-size:.88rem; color:var(--ice); font-family:var(--font-accent); font-style:italic; max-width:480px; margin-left:auto; margin-right:auto; }
  .lb-close, .lb-prev, .lb-next{ position:absolute; background:none; border:none; color:var(--white); font-size:1.6rem; cursor:pointer; padding:.6rem; opacity:.85; transition:opacity .2s ease; }
  .lb-close:hover, .lb-prev:hover, .lb-next:hover{ opacity:1; }
  .lb-close{ top:1.2rem; right:1.5rem; font-size:1.8rem; }
  .lb-prev{ left:1rem; top:50%; transform:translateY(-50%); font-size:2rem; }
  .lb-next{ right:1rem; top:50%; transform:translateY(-50%); font-size:2rem; }
  #final-message{ background: radial-gradient(circle at 50% 20%, var(--blue) 0%, var(--void) 65%); }
  .stars-layer{ position:absolute; inset:0; z-index:0; overflow:hidden; }
  .star-dot{ position:absolute; background:#fff; border-radius:50%; opacity:.6; animation: twinkle 3s ease-in-out infinite; }
  @keyframes twinkle{ 0%,100%{ opacity:.2;} 50%{ opacity:.9;} }
  .final-card{ position:relative; z-index:2; max-width:640px; width:100%; }
  .final-text{ font-family:var(--font-accent); font-size:1.1rem; line-height:2; color:var(--ice); text-align:left; white-space:pre-line; }
  #letter-page{ background:var(--void); overflow:hidden; }
  .envelope-scene{ position:relative; perspective:1200px; width:min(320px,84vw); margin:0 auto; }
  .envelope{ position:relative; width:100%; aspect-ratio:16/10; }
  .env-body{ position:absolute; inset:0; background:linear-gradient(180deg,#12193f,#0a1130); border-radius:6px; box-shadow:0 20px 50px rgba(0,0,0,0.5); border:1px solid rgba(242,169,196,0.25); overflow:hidden; }
  .env-body::before, .env-body::after{ content:''; position:absolute; bottom:0; width:0; height:0; border-style:solid; }
  .env-body::before{ left:0; border-width:0 0 90px 160px; border-color:transparent transparent rgba(255,255,255,0.03) transparent; }
  .env-body::after{ right:0; border-width:90px 160px 0 0; border-color:transparent transparent transparent rgba(255,255,255,0.03); }
  .env-flap{ position:absolute; top:0; left:0; width:100%; height:60%; background:linear-gradient(160deg,#1a2352,#0e1638); clip-path:polygon(0 0, 100% 0, 50% 100%); transform-origin:top center; transition: transform 1.1s cubic-bezier(.5,0,.2,1); z-index:3; border-bottom:1px solid rgba(242,169,196,0.2); }
  .envelope.open .env-flap{ transform: rotateX(180deg); }
  .env-seal{ position:absolute; top:26%; left:50%; transform:translate(-50%,-50%); z-index:4; width:44px; height:40px; cursor:pointer; background:none; border:none; filter: drop-shadow(0 0 12px #fff) drop-shadow(0 0 22px var(--pink)); animation: heartPulse 3s ease-in-out infinite; }
  .env-seal svg{ width:100%; height:100%; }
  .envelope.open .env-seal{ opacity:0; pointer-events:none; transition:opacity .4s ease; }
  .env-prompt{ margin-top:1.4rem; font-family:var(--font-display); font-size:.85rem; letter-spacing:.1em; color:var(--silver); }
  .letter-paper{ position:relative; z-index:2; margin-top:2.4rem; max-width:560px; width:100%; background: linear-gradient(180deg,#fdf6ea,#f6ecd8); border-radius:4px; padding:2.4rem 2rem; box-shadow:0 30px 70px rgba(0,0,0,0.5); opacity:0; transform:translateY(30px); transition: opacity 1.1s ease, transform 1.1s ease; }
  .letter-paper.show{ opacity:1; transform:translateY(0); }
